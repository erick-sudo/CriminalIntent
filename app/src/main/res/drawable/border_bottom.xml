<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity=""
        android:left="0dp"
        android:right="0dp">
        <shape>
            <size android:height="2dp" />
            <solid android:color="#904D4618" />
        </shape>
    </item>
    <item
        android:gravity="bottom"
        android:left="16dp"
        android:right="16dp">
        <shape>
            <size android:height="1dp" />
            <solid android:color="#CE2F7F04" />
        </shape>
    </item>

</layer-list>